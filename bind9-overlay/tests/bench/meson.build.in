# --- efficios-trie-benchmark overlay -------------------------------------
# This file is rendered from meson.build.in by scripts/build-bind9.sh, which
# substitutes the @URCU_*@ placeholders with paths to our own out-of-tree
# liburcu build (the Fractal Trie).  It replaces bind9's upstream
# tests/bench/meson.build to add the FT-vs-others benchmark executables:
#   load-names           (bind9 "lookup names" MT scaling test, FT_PRIME priming)
#   qpmulti_ft           (FT integration into bind9's qpmulti bench)
#   bench_scale_rw_bind9 (FT vs vendored Judy/qp-trie/ART vs BIND9 QP, rw scaling)
# -------------------------------------------------------------------------

foreach bench : [
    'ascii',
    'compress',
    'iterated_hash',
    'qp-dump',
    'qplookups',
    'qpmulti',
    'siphash',
]
    executable(
        bench,
        files(fs.replace_suffix(bench, '.c')),
        export_dynamic: true,
        install: false,
        sources: default_sanitize_options,
        dependencies: [
            libisc_dep,
            libdns_dep,
            libns_dep,
            libtest_dep,
        ],
    )
endforeach

# Our own in-tree liburcu clone build (the Fractal Trie).  Headers and the
# library both live under our clone, so a single include dir suffices.
#
# NOTE: bind9's own libs (libdns/libisc) link the system liburcu-cds found via
# pkg-config, and pull it in transitively, so at *run time* you must put our
# build's .libs first on the library path, otherwise an older system
# liburcu-cds wins and FT symbols go missing:
#   LD_LIBRARY_PATH=@URCU_LIBDIR@ ./tests/bench/load-names <names.csv>
urcu_cds_dep = declare_dependency(
    include_directories: include_directories('@URCU_INC@'),
    link_args: [
        '-L@URCU_LIBDIR@',
        '-Wl,-rpath,@URCU_LIBDIR@',
        '@URCU_LIBDIR@/liburcu-cds.so',
    ],
)

# Standalone FT/B9QP dep: also links liburcu.so (the membarrier flavor that
# provides urcu_memb_*), which liburcu-cds.so does NOT pull in.  The
# bind9-linked benches get the base liburcu transitively via libdns/libisc, but
# the per-engine FT executable links no bind9, so it needs it explicitly.
urcu_ft_dep = declare_dependency(
    include_directories: include_directories('@URCU_INC@'),
    link_args: [
        '-L@URCU_LIBDIR@',
        '-Wl,-rpath,@URCU_LIBDIR@',
        '@URCU_LIBDIR@/liburcu-cds.so',
        '@URCU_LIBDIR@/liburcu.so',
    ],
)

# As urcu_ft_dep, but links the QSBR flavor (liburcu-qsbr, providing
# urcu_qsbr_*) instead of the membarrier liburcu.  Used by bench_scale_ft_qsbr,
# the QSBR build of the same FT engine source (-DBENCH_FT_QSBR): QSBR's read
# side is free (rcu_read_lock/unlock compile to nothing), trading a stricter
# quiescent-state/offline discipline for lower reader overhead at scale.
urcu_ft_qsbr_dep = declare_dependency(
    include_directories: include_directories('@URCU_INC@'),
    link_args: [
        '-L@URCU_LIBDIR@',
        '-Wl,-rpath,@URCU_LIBDIR@',
        '@URCU_LIBDIR@/liburcu-cds.so',
        '@URCU_LIBDIR@/liburcu-qsbr.so',
    ],
)

bench_threads_dep = dependency('threads')
# bench_scale_common.c can interleave allocations across NUMA nodes
# (BENCH_NUMA_INTERLEAVE); every bench_scale_* engine links it, so all need libnuma.
bench_numa_dep = meson.get_compiler('c').find_library('numa')

executable(
    'load-names',
    files('load-names.c'),
    export_dynamic: true,
    install: false,
    sources: default_sanitize_options,
    dependencies: [
        urcu_cds_dep,
        libisc_dep,
        libdns_dep,
        libns_dep,
        libtest_dep,
    ],
)
executable(
    'qpmulti_ft',
    files('qpmulti_ft.c'),
    export_dynamic: true,
    install: false,
    sources: default_sanitize_options,
    dependencies: [
        urcu_cds_dep,
        libisc_dep,
        libdns_dep,
        libns_dep,
        libtest_dep,
    ],
)

# EfficiOS read/write scaling benchmark, split one engine per executable so
# each structure's RSS can be measured in isolation (one process = one trie).
# scripts/run_scale_rw.sh runs them all and assembles the combined table.
#
# Only bench_scale_b9qp links bind9 (libisc/libdns); the other four engines
# link neither bind9 nor (for the rwlock engines) liburcu.  This is also why
# the hang is gone: libisc's constructor registers the main thread with RCU, so
# pulling it into only one executable removes the double-registration that
# corrupted the RCU registry.  bench_scale_common.c is shared by all five.
#
# The qp/art executables compile the vendored qp-trie (Tbl.c + qp.c) and libart
# (art.c) sources that build-bind9.sh copies here; their warnings are silenced
# (-w) and werror disabled so they don't trip bind9's -Werror.

executable(
    'bench_scale_ft',
    files('bench_scale_ft.c', 'bench_scale_common.c'),
    export_dynamic: true,
    install: false,
    include_directories: include_directories('.'),
    sources: default_sanitize_options,
    dependencies: [urcu_ft_dep, bench_threads_dep, bench_numa_dep],
)

# QSBR build of the very same FT engine source — only the RCU flavor differs
# (-DBENCH_FT_QSBR selects <urcu/urcu-qsbr.h> + the offline discipline), so
# this isolates read-side flavor cost: ft (membarrier) vs ft_qsbr (QSBR).
executable(
    'bench_scale_ft_qsbr',
    files('bench_scale_ft.c', 'bench_scale_common.c'),
    export_dynamic: true,
    install: false,
    include_directories: include_directories('.'),
    sources: default_sanitize_options,
    c_args: ['-DBENCH_FT_QSBR'],
    dependencies: [urcu_ft_qsbr_dep, bench_threads_dep, bench_numa_dep],
)

executable(
    'bench_scale_judy',
    files('bench_scale_judy.c', 'bench_scale_common.c'),
    export_dynamic: true,
    install: false,
    include_directories: include_directories('.'),
    sources: default_sanitize_options,
    dependencies: [bench_threads_dep, bench_numa_dep],
    link_args: ['-lJudy'],
)

executable(
    'bench_scale_qp',
    files('bench_scale_qp.c', 'bench_scale_common.c', 'Tbl.c', 'qp.c'),
    export_dynamic: true,
    install: false,
    include_directories: include_directories('.'),
    sources: default_sanitize_options,
    c_args: ['-w'],
    override_options: ['werror=false'],
    dependencies: [bench_threads_dep, bench_numa_dep],
)

executable(
    'bench_scale_art',
    files('bench_scale_art.c', 'bench_scale_common.c', 'art.c'),
    export_dynamic: true,
    install: false,
    include_directories: include_directories('.'),
    sources: default_sanitize_options,
    c_args: ['-w'],
    override_options: ['werror=false'],
    dependencies: [bench_threads_dep, bench_numa_dep],
)

executable(
    'bench_scale_b9qp',
    files('bench_scale_b9qp.c', 'bench_scale_common.c'),
    export_dynamic: true,
    install: false,
    include_directories: include_directories('.'),
    sources: default_sanitize_options,
    dependencies: [
        urcu_ft_dep,
        libisc_dep,
        libdns_dep,
        libns_dep,
        libtest_dep,
        bench_numa_dep,
    ],
)

executable(
    'dns_name_fromwire',
    files(
        'dns_name_fromwire.c',
        meson.project_source_root() / 'fuzz' / 'old.c',
    ),
    export_dynamic: true,
    include_directories: '..' / '..' / 'fuzz',
    install: false,
    sources: default_sanitize_options,
    dependencies: [
        libisc_dep,
        libdns_dep,
        libns_dep,
        libtest_dep,
    ],
)
